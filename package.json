{
  "name": "lioconecta-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "report:observability": "node tools/generate-observability-e2e-report.mjs",
    "generate:politicas-pdfs": "python scripts/generate-politicas-pdfs.py",
    "generate:manuais-pdfs": "python scripts/generate-manuais-pdfs.py",
    "generate:formularios-pdfs": "python scripts/generate-formularios-pdfs.py",
    "generate:modelos-pdfs": "python scripts/generate-modelos-pdfs.py",
    "generate:biblioteca-pdfs": "python scripts/generate-biblioteca-pdfs.py",
    "extract": "python scripts/migrate-to-react.py && python scripts/generate-pages-index.py && python scripts/fix-css-urls.py",
    "docs:roadmap": "npx --yes serve docs/roadmap -p 4173",
    "docs:transforma": "npx --yes serve docs/transforma -p 4174",
    "render:intro-video": "node tools/render-intro-video.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.16.0",
    "@azure/msal-react": "^5.5.1",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/extension-youtube": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
