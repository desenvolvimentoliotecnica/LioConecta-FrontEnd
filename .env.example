# LioConecta Front-end — variáveis de ambiente

# Backend API — use caminho relativo para o proxy Vite (evita CORS em dev)
VITE_API_BASE_URL=/api/v1

# Origin da API para mídias (/posts/medias, /media/...). Opcional em dev (padrão: http://localhost:5148)
# VITE_API_ORIGIN=http://localhost:5148

# true = ignora API e usa mocks locais no React; false = consome API (modo simulação do backend)
VITE_USE_MOCK=false

# Telemetria operacional (page views, erros FE) — false desabilita envio batch
VITE_OBSERVABILITY_ENABLED=true

# Azure AD: configurado em /admin/configuracoes-backend (seções azure_ad e calendário).
# Variáveis VITE_AZURE_* não são mais utilizadas pelo frontend.

# Compass standalone (URL da SPA LioConecta.Compass.FrontEnd).
# Quando definido, o menu Compass abre a app própria com handoff JWT (?token=).
# Vazio = mantém o módulo embutido no portal.
VITE_COMPASS_APP_URL=http://localhost:5174

# UniLio standalone (URL da SPA LioConecta.UniLio.FrontEnd).
# Quando definido, o menu UniLio abre a app própria com handoff JWT (?token=).
# Vazio = mantém o módulo embutido no portal.
VITE_UNILIO_APP_URL=
