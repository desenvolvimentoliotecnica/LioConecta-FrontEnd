# LioConecta Front-end — variáveis de ambiente

# Backend API — use caminho relativo para o proxy Vite (evita CORS em dev)
VITE_API_BASE_URL=/api/v1

# true = ignora API e usa mocks locais no React; false = consome API (modo simulação do backend)
VITE_USE_MOCK=false

# Telemetria operacional (page views, erros FE) — false desabilita envio batch
VITE_OBSERVABILITY_ENABLED=true

# Azure AD (deixe vazio em dev — backend usa DevAuth)
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_API_SCOPE=api://lioconecta/access_as_user
